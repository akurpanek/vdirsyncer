[general]
status_path = "./status/"

# Pair for Google -> Nextcloud
[pair sync_pair1]
a = "GOOGLE"
b = "NEXTCLOUD1"
collections = [
    ["google_to_nextcloud", "${GOOGLE_COL}", "${NEXTCLOUD_COL}"]
]
conflict_resolution = "a wins"

# Pair for Nextcloud -> mailbox.org
[pair sync_pair2]
a = "NEXTCLOUD2"
b = "MAILBOX"
# Map the specific collection from CARDDAV1 to the specific collection on CARDDAV2
collections = [
    ["nextcloud_to_mailbox", "${NEXTCLOUD_COL}", "${MAILBOX_COL}"]
  ]
conflict_resolution = "a wins"

# Storage Definition for Google Contacts
[storage GOOGLE]
type = "carddav"
url = "$GOOGLE_URL"
username = "$GOOGLE_USER"
password.fetch = ["shell", "echo $GOOGLE_PWD"]

# Storage Definition for Nextcloud Contacts sync with GOOGLE
[storage NEXTCLOUD1]
type = "carddav"
url = "$NEXTCLOUD_URL"
username = "$NEXTCLOUD_USER"
password.fetch = ["shell", "echo $NEXTCLOUD_PWD"]

# Storage Definition for Nextcloud Contacts sync with mailbox.org
[storage NEXTCLOUD2]
type = "carddav"
url = "$NEXTCLOUD_URL"
username = "$NEXTCLOUD_USER"
password.fetch = ["shell", "echo $NEXTCLOUD_PWD"]
# Asynchron: NEXTCLOUD is read-only; changes there will be pushed to CARDDAV2.
read_only = true

# Storage Definition for mailbox.org Contacts
[storage MAILBOX]
type = "carddav"
url = "$MAILBOX_URL"
username = "$MAILBOX_USER"
password.fetch = ["shell", "echo $MAILBOX_PWD"]
